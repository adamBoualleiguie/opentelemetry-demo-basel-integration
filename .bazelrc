# M0: Bzlmod-only workspace (no WORKSPACE dependencies).
common --enable_bzlmod

# Java gRPC codegen pulls Abseil C++ (host tools); default GCC often defaults to pre-C++17.
common --host_cxxopt=-std=c++17
common --cxxopt=-std=c++17

# Avoid host GOEXPERIMENT leaking into Go stdlib / go_repository fetch (e.g. unknown coverageredesign).
common --action_env=GOEXPERIMENT=
common --repo_env=GOEXPERIMENT=

# --- Profiles (see docs/bazel/milestones/m0-completion.md) ---
build:dev --announce_rc

build:ci --announce_rc
build:ci --color=yes
build:ci --curses=no
# Reserved for later milestones (M5+ / release).
build:release --announce_rc

# Reserved for integration / trace / e2e-heavy runs.
build:integration --announce_rc

test:ci --test_output=errors

# BZ-130 / M3: global test tag convention (see docs/bazel/milestones/m3-completion.md § Epic N).
# Examples: bazel test //... --config=unit
test:unit --test_tag_filters=unit,-integration,-e2e,-trace,-slow,-manual
test:integration --test_tag_filters=integration,-e2e,-trace,-slow,-manual
test:e2e --test_tag_filters=e2e
test:trace --test_tag_filters=trace
